    "@kobalte/core": "^0.13.11",
    "@tanstack/solid-db": "^0.2.12",
    "@tanstack/solid-query": "^5.90.26",
    "@tanstack/solid-router": "^1.166.7",
    "cva": "^1.0.0-beta.4",
    "dayjs": "^1.11.20",
    "lucide-solid": "^0.577.0",
    "radashi": "^12.7.2",
    "solid-js": "^1.9.11",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "valibot": "^1.2.0",
    "xior": "^0.8.3"
  },
  "devDependencies": {
